generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  category    String
  description String
  priceUnit   Int?     // Usamos enteros para pesos chilenos (CLP)
  priceBox    Int?
  imageUrl    String
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Hash seguro con bcryptjs
  createdAt DateTime @default(now())
}
